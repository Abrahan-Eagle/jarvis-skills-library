# JARVIS feature loop — copy to repo producto as skill-loop.yml
# yaml-language-server: $schema=skills/ops/skill-loop/references/schema.json
# (from jarvis-skills-library clone) or vendor schema.json beside this file

name: jarvis-feature-loop
default_entrypoint: implement
max_iterations: 5
idle_timeout_seconds: 900
max_restarts: 2

router:
  runtime: cursor-cli
  model: gpt-5

skills:
  implement:
    agent:
      runtime: cursor-cli
      model: gpt-5
    next:
      - id: to-review
        skill: review

  review:
    agent:
      runtime: cursor-cli
      model: gpt-5
    next:
      - id: approve
        criteria: "Review confirms implementation quality is sufficient for this iteration."
        skill: verify
      - id: ask-human
        criteria: "Review needs a human decision before continuing."
        blocked: true
        skill: implement
      - id: rework
        criteria: "Review found issues that require more implementation work."
        skill: implement

  verify:
    agent:
      runtime: cursor-cli
      model: gpt-5
    next:
      - id: done
        criteria: "Tests pass and verification-before-completion criteria met."
        done: true
      - id: rework
        criteria: "Tests or verification failed; more implementation needed."
        skill: implement
