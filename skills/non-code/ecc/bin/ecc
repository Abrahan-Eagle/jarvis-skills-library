#!/usr/bin/env bash
# ecc — wrapper JARVIS para CLI ECC upstream (Everything Claude Code)
set -euo pipefail

usage() {
  cat <<'EOF'
ecc <command> [options]

Comandos:
  status              Detecta hooks, agents ecc-*, ECC CLI, ECC_HOME
  consult <query>     ecc consult (default --target cursor)
  doctor              Diagnóstico harness
  repair              Reparación harness
  help

Variables:
  ECC_HOME            Clone ECC (default: $HOME/ecc)
  ECC_TARGET          Target consult (default: cursor)

Ejemplos:
  ecc status
  ecc consult "laravel security review"
  ecc doctor
EOF
}

ECC_HOME="${ECC_HOME:-$HOME/ecc}"
ECC_TARGET="${ECC_TARGET:-cursor}"

run_ecc_cli() {
  if [ -f "$ECC_HOME/scripts/ecc.js" ]; then
    node "$ECC_HOME/scripts/ecc.js" "$@"
    return
  fi
  if command -v ecc >/dev/null 2>&1 && ecc --help 2>/dev/null | grep -q consult; then
    ecc "$@"
    return
  fi
  if command -v npx >/dev/null 2>&1; then
    npx --yes ecc-universal "$@" || npx --yes ecc "$@"
    return
  fi
  echo "ECC CLI no disponible — clone en ECC_HOME o npm install ecc-universal" >&2
  return 127
}

ecc_cli_ok() {
  [ -f "$ECC_HOME/scripts/ecc.js" ] && return 0
  command -v ecc >/dev/null 2>&1 && return 0
  command -v ecc-universal >/dev/null 2>&1 && return 0
  return 1
}

cmd_status() {
  local hooks=0 agents=0 cli=0 home=0
  if [ -f .cursor/hooks.json ] && grep -q ecc .cursor/hooks.json 2>/dev/null; then
    hooks=1
  fi
  if [ -d .cursor/agents ]; then
    local a
    a=$(ls .cursor/agents/ecc-*.md .cursor/agents/*.md 2>/dev/null | head -1 || true)
    [ -n "$a" ] && agents=1
  fi
  if ecc_cli_ok; then
    cli=1
  fi
  [ -d "$ECC_HOME" ] && home=1
  echo "ecc_hooks=$hooks ecc_agents=$agents ecc_cli=$cli ecc_home=$home home=$ECC_HOME target=$ECC_TARGET"
  if [ "$cli" -eq 1 ] && [ -f "$ECC_HOME/scripts/ecc.js" ]; then
    node "$ECC_HOME/scripts/ecc.js" status 2>/dev/null | head -3 || true
  fi
}

cmd_consult() {
  local query="${1:-}"
  [ -n "$query" ] || { echo "consult requiere query" >&2; exit 2; }
  run_ecc_cli consult "$query" --target "$ECC_TARGET"
}

cmd_doctor() {
  run_ecc_cli doctor --target "$ECC_TARGET"
}

cmd_repair() {
  run_ecc_cli repair --target "$ECC_TARGET"
}

main() {
  local cmd=${1:-help}
  shift || true
  case "$cmd" in
    status) cmd_status "$@";;
    consult) cmd_consult "$@";;
    doctor) cmd_doctor "$@";;
    repair) cmd_repair "$@";;
    help|-h|--help) usage;;
    *) usage; exit 2;;
  esac
}

main "$@"
